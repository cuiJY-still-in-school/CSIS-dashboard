{
  "type": "object",
  "properties": {
    "autoStartServer": {
      "type": "boolean",
      "default": true,
      "description": "Automatically start the dashboard web server on load"
    },
    "serverPort": {
      "type": "number",
      "default": 3000,
      "minimum": 1024,
      "maximum": 65535,
      "description": "Port for the dashboard web server"
    },
    "enableDragAndDrop": {
      "type": "boolean",
      "default": true,
      "description": "Enable drag-and-drop positioning of components"
    },
    "theme": {
      "type": "string",
      "enum": ["dark", "light", "auto"],
      "default": "dark",
      "description": "Dashboard theme"
    },
    "layoutGridSize": {
      "type": "number",
      "default": 12,
      "description": "Number of columns in the layout grid"
    }
  },
  "required": ["autoStartServer", "serverPort"]
}